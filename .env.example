# SentinelAudit Configuration
#
# Backend environment variables are configured in:
#   backend/.env.example  →  backend/.env
#
# Frontend environment variables are configured in:
#   frontend/.env.example →  frontend/.env
#
# For Docker Compose, use the environment variable overrides
# documented in docker-compose.yml (all have ${VAR:-default} syntax).

ENVIRONMENT=development
