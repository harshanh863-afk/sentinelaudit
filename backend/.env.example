# SentinelAudit Backend Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# Runtime mode: development, production, testing
ENVIRONMENT=development

# PostgreSQL connection string
DATABASE_URL=postgresql://sentinelaudit:sentinelaudit@localhost:5432/sentinelaudit

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Secret key for session signing (min 32 characters in production)
SECRET_KEY=dev-secret-key-change-in-production

# Frontend URL for CORS (exact origin)
FRONTEND_URL=http://localhost:5173

# Debug mode (must be false in production)
DEBUG=true

# Public scan rate limit (scans per IP per hour)
PUBLIC_SCAN_MAX_PER_HOUR=5

# Scanner timeout in seconds
SCANNER_TIMEOUT=30

# Max concurrent scans
MAX_CONCURRENT_SCANS=5

# Scan results TTL in seconds (default: 24h)
SCAN_RESULTS_TTL=86400
